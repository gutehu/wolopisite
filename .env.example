# Base de données (Neon + Prisma)
# - DATABASE_URL : connexion "pooled" (pooler) pour l'app (runtime)
# - DIRECT_URL   : connexion "direct" pour Prisma Migrate (migrations)
DATABASE_URL="postgresql://user:password@ep-xxxxxx-pooler.eu-west-1.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxxxxx.eu-west-1.aws.neon.tech/neondb?sslmode=require"

# URL publique du site (liens, CORS, redirections)
# En dev : optionnel (défaut http://localhost:3000)
# En prod (Vercel) : ex. https://wolopi.fr ou https://xxx.vercel.app
# NEXT_PUBLIC_APP_URL="https://votre-site.fr"

# CORS : origines autorisées pour l’app mobile (séparées par des virgules)
# En dev : toutes les origines (*) pour tests USB / simulateurs
# En prod : ex. https://wolopi.fr ou les origines de vos apps
# CORS_ALLOWED_ORIGINS="https://wolopi.fr"
